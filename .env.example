# Service port
PORT=3010

# HTTP request log format
# Options: tiny, combined, common, dev, short
# tiny: Most compact format, includes method, URL, status code, response time
# combined: Standard Apache combined log format, includes IP, time, request, status code, response size, referrer, user-agent
# common: Standard Apache common log format, similar to combined but without referrer and user-agent
# dev: Developer-friendly colored format, includes method, URL, status code (with color), response time
# short: Shorter format, includes method, URL, status code, response time, response size
MORGAN_FORMAT=tiny

# API Key to Cookie mapping (JSON format)
# Format: {"custom_api_key": "Cookie value"} or {"custom_api_key": ["Cookie value1", "Cookie value2"]}
API_KEYS={"sk-cursor-123":"user_xxxxxxx","sk-cursor-456":["user_yyyyyyy","user_zzzzzzz"]}

# Rotation strategy (random or round-robin or default)
ROTATION_STRATEGY=default

# Cursor checksum (optional)
# x-cursor-checksum=xxxxxxxx 

# Auto-refresh Cookie settings
# Whether to enable auto-refresh Cookie (true or false)
ENABLE_AUTO_REFRESH=false

# Auto-refresh Cookie schedule (Cron expression)
# Default: every 6 hours
REFRESH_CRON=0 */6 * * *

# Minimum Cookie count per API Key
# When Cookie count falls below this value, auto-refresh will be attempted
MIN_COOKIE_COUNT=1000

# Cookie refresh mode
# replace: Each refresh marks all existing cookies as invalid and replaces them with new cookies (default)
# append: Keep existing cookies, only append new cookies
COOKIE_REFRESH_MODE=replace

# GitHub repository information
GITHUB_OWNER=your_name
GITHUB_REPO=Cursor-Register-fix

# GitHub Token (for downloading Artifact from GitHub Actions)
# Requires repo permission
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Actions workflow ID
# Used to trigger the workflow
GITHUB_WORKFLOW_ID=cursor_register.yml

# Whether to auto-trigger workflow
# When set to true, will auto-trigger workflow instead of only fetching latest result
TRIGGER_WORKFLOW=true

# Workflow parameter settings - currently only supports Gmail, Outlook is too complex and not supported yet
# Number of accounts to register
REGISTER_NUMBER=1
# Maximum concurrent worker threads
REGISTER_MAX_WORKERS=1
# Email server type (TempEmail or IMAP)
REGISTER_EMAIL_SERVER=IMAP
# Whether to inject account tokens into OneAPI (true or false)
REGISTER_INGEST_TO_ONEAPI=false
# Whether to upload account info to Artifact (true or false)
REGISTER_UPLOAD_ARTIFACT=true
# Whether to read email config from config.yaml (true or false)
REGISTER_USE_CONFIG_FILE=false
# Email config JSON string (only valid when REGISTER_USE_CONFIG_FILE=false)
# Format example: [{"email":"example@gmail.com","imap_server":"imap.gmail.com","imap_port":993,"username":"example@gmail.com","password":"your_app_password"}]
REGISTER_EMAIL_CONFIGS=[]

# Logging system configuration
LOG_LEVEL=INFO  # ERROR, WARN, INFO, DEBUG, TRACE
LOG_FORMAT=colored  # colored, json, text
LOG_TO_FILE=false
LOG_MAX_SIZE=10  # Unit: MB
LOG_MAX_FILES=10  # Number of historical log files to retain

# Proxy server configuration
# Whether to use TLS proxy server (true or false)
USE_TLS_PROXY=true
# Whether to use other interface proxy server (true or false)
USE_OTHERS_PROXY=true

# Proxy server platform
# Options: auto, windows_x64, linux_x64, android_arm64
# auto: Auto-detect platform
# windows_x64: Windows 64-bit
# linux_x64: Linux 64-bit
# android_arm64: Android ARM 64-bit
PROXY_PLATFORM=auto 

# Whether to use other interfaces (true or false)
USE_OTHERS=true